{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Crewly",
  "description": "Crewly is a next-generation staff & operations management platform built specifically for Ro-Aviation groups. It aims to replace spreadsheets, messy logs, and fragmented bots with one unified, modular system designed to scale from small airlines to full enterprise-level operations.",
  "colors": {
    "primary": "#22C55E",
    "light": "#22C55E",
    "dark": "#16A34A"
  },
  "favicon": {
    "light": "/images/Crewly.ico",
    "dark": "/images/Crewly.ico"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "layout-dashboard",
          "href": "https://dash.crewlyrblx.app"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get Started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "introduction",
          "quickstart",
          "connecting-your-group"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/CREWLYlight.png",
    "dark": "/images/crewlybanner.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "background": {
    "decoration": "gradient"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/introduction",
      "permanent": false
    }
  ]
}
